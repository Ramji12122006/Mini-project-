@charset "utf-8";

:root { --color-bg: #0D1B0E; --color-text: #F4FBF4; --glow-color-rgb: 34,197,94; }

* { box-sizing: border-box; }

html, body { margin: 0px; background: var(--color-bg); overflow: hidden; }

