@charset "utf-8";

:root { --color-bg: #0D1B0E; --color-text: #F5FFF4; --glow-color-rgb: 34,197,94; --color-glass-bg: rgba(255,255,255,0.05); --color-glass-border: rgba(255,255,255,0.09); --font-body: 'Inter',sans-serif; }

*, ::before, ::after { box-sizing: border-box; }

html, body { background: var(--color-bg); margin: 0px; }

body { font-family: var(--font-body); color: var(--color-text); overflow: hidden; height: 100vh; width: 100vw; }

.deck { width: 100vw; height: 100vh; position: relative; }

.slide { position: absolute; top: 0px; left: 0px; width: 100%; height: 100%; background: var(--color-bg); display: flex; flex-direction: column; align-items: center; justify-content: center; opacity: 0; transform: scale(0.95); transition: opacity 0.7s, transform 0.7s; pointer-events: none; overflow: hidden; }

.slide.active { opacity: 1; transform: scale(1); pointer-events: all; }

.slide > .content { position: relative; z-index: 2; width: 100%; max-width: 1160px; padding: clamp(1.4rem, 3vw, 3rem); }

.nav-controls { position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%); display: flex; align-items: center; gap: 16px; z-index: 100; background: var(--color-glass-bg); backdrop-filter: blur(10px); padding: 10px 24px; border-radius: 40px; border: 1px solid var(--color-glass-border); }

.nav-btn { width: 40px; height: 40px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; background: var(--color-glass-bg); color: rgb(34, 197, 94); border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; }

.slide-dots { display: flex; gap: 8px; }

.dot { width: 10px; height: 10px; border-radius: 50%; background: var(--color-glass-border); cursor: pointer; }

.dot.active { background: rgb(34, 197, 94); transform: scale(1.25); }

.slide-counter { font-size: 0.8rem; color: rgb(157, 183, 156); min-width: 50px; text-align: center; }

.reveal { opacity: 0; transform: translateY(20px); }

@keyframes float-slow { 
  0% { transform: translate(0px, 0px) scale(1); }
  25% { transform: translate(60px, -50px) scale(1.12); }
  50% { transform: translate(-40px, 40px) scale(0.9); }
  75% { transform: translate(50px, 20px) scale(1.08); }
  100% { transform: translate(0px, 0px) scale(1); }
}

@keyframes float-drift { 
  0% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
  33% { transform: translate(-50px, -60px) scale(1.15) rotate(3deg); }
  66% { transform: translate(40px, 30px) scale(0.88) rotate(-2deg); }
  100% { transform: translate(0px, 0px) scale(1) rotate(0deg); }
}

@keyframes float { 
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-15px); }
}

@keyframes glow-pulse { 
  0%, 100% { text-shadow: 0 0 20px rgba(var(--glow-color-rgb),.5),0 0 40px rgba(var(--glow-color-rgb),.2); }
  50% { text-shadow: 0 0 30px rgba(var(--glow-color-rgb),.8),0 0 60px rgba(var(--glow-color-rgb),.3); }
}

.glow-pulse { animation: 3s ease-in-out 0s infinite normal none running glow-pulse; }

.gradient-mesh { position: absolute; inset: 0px; z-index: 0; overflow: hidden; pointer-events: none; }

.blob { position: absolute; border-radius: 50%; filter: blur(80px); animation: 10s ease-in-out 0s infinite normal none running float-slow; }

.blob:nth-child(2) { animation: 14s ease-in-out 0s infinite normal none running float-drift; }

.blob:nth-child(3) { animation: 18s ease-in-out 0s infinite reverse none running float-slow; }

.slide::before { content: ""; position: absolute; inset: 0px; z-index: 1; pointer-events: none; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); background-repeat: repeat; background-size: 256px 256px; opacity: 0.03; mix-blend-mode: overlay; }

.slide::after { content: ""; position: absolute; inset: 0px; z-index: 1; pointer-events: none; background: radial-gradient(ellipse at center,transparent 50%,var(--color-vignette) 100%); }

.bar-track { height: 18px; background: rgba(255, 255, 255, 0.09); border-radius: 999px; overflow: hidden; }

.bar-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg, rgb(34, 197, 94), rgb(96, 165, 250)); width: 0px; }

.ascii-box { white-space: pre; font-family: monospace; background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 1rem; color: rgb(217, 247, 221); font-size: 0.83rem; line-height: 1.25; }

table { width: 100%; border-collapse: collapse; }

th, td { border: 1px solid rgba(255, 255, 255, 0.09); padding: 0.55rem 0.6rem; vertical-align: top; }

th { background: rgba(255, 255, 255, 0.07); font-weight: 700; }

.mini { font-size: 0.82rem; line-height: 1.25; }

.tight li { margin-bottom: 0.45rem; }

@media (prefers-reduced-motion: reduce) {
  *, ::before, ::after { animation-duration: 0.01ms !important; transition-duration: 0.2s !important; }
}
