import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class Login extends JFrame implements ActionListener {

    JLabel title, userLabel, passLabel;
    JTextField userText;
    JPasswordField passText;
    JButton loginBtn, clearBtn;

    Login() {

        setTitle("Green Hydrogen Management System - Login");
        setSize(450, 300);
        setLocationRelativeTo(null);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLayout(null);

        title = new JLabel("GREEN HYDROGEN MANAGEMENT SYSTEM");
        title.setBounds(40, 20, 350, 30);
        title.setFont(new Font("Arial", Font.BOLD, 16));
        add(title);

        userLabel = new JLabel("Username:");
        userLabel.setBounds(60, 80, 100, 25);
        add(userLabel);

        userText = new JTextField();
        userText.setBounds(170, 80, 180, 25);
        add(userText);

        passLabel = new JLabel("Password:");
        passLabel.setBounds(60, 120, 100, 25);
        add(passLabel);

        passText = new JPasswordField();
        passText.setBounds(170, 120, 180, 25);
        add(passText);

        loginBtn = new JButton("Login");
        loginBtn.setBounds(90, 180, 100, 35);
        loginBtn.addActionListener(this);
        add(loginBtn);

        clearBtn = new JButton("Clear");
        clearBtn.setBounds(230, 180, 100, 35);
        clearBtn.addActionListener(this);
        add(clearBtn);

        getContentPane().setBackground(new Color(220, 245, 255));

        setVisible(true);
    }

    public void actionPerformed(ActionEvent e) {

        if (e.getSource() == loginBtn) {

            String username = userText.getText();
            String password = String.valueOf(passText.getPassword());

            if (username.equals("admin") && password.equals("admin123")) {
                JOptionPane.showMessageDialog(this,
                        "Login Successful!");
            } else {
                JOptionPane.showMessageDialog(this,
                        "Invalid Username or Password");
            }

        }

        if (e.getSource() == clearBtn) {
            userText.setText("");
            passText.setText("");
        }
    }

    public static void main(String[] args) {
        new Login();
    }
}
